{
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.perfectsecuritysolution.in" }],
      "destination": "https://perfectsecuritysolution.in/:path*",
      "permanent": true
    }
  ]
}
